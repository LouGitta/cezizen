# ==========================================
# Configuration CesiZen (.env)
# ==========================================

# Environnement (dev ou prod)
ENVIRONMENT=prod

# Tag de l'image Docker à tirer de GHCR (develop pour le serveur DEV, latest pour la PROD)
IMAGE_TAG=latest

# Mode Debug (Mettre à False en production / True en développement)
DEBUG=False

# Clé secrète Django (Générer une clé robuste en production)
SECRET_KEY=

# Configuration Base de Données (PostgreSQL)
POSTGRES_DB=cesi_zen
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cesi_zen_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
